# Reyval local payment server configuration

# Server port
REYVAL_PORT=3000

# Razorpay credentials
# Use test keys first while validating checkout end to end.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Firebase Admin SDK credentials for Firestore order + product storage.
# Option 1: paste the full service-account JSON string (or base64-encoded JSON).
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
#
# Option 2: provide the individual fields below.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=

# Optional Firestore collection overrides
FIREBASE_ORDERS_COLLECTION=reyval_orders
FIREBASE_PRODUCTS_COLLECTION=reyval_products
FIREBASE_CUSTOMERS_COLLECTION=reyval_customers

# Optional browser override if your API is hosted elsewhere.
# Leave empty when running `node server.mjs` in this repo.
# REYVAL_API_BASE=http://localhost:3000

# Google Drive configuration for bill storage
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/..."}
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-here
